{
  "title": "VLA Egocentric — Robotics Manipulation",
  "description": "Vision-Language-Action ontology for egocentric robot video annotation. Designed for training VLA models on humanoid robot manipulation tasks. Verb+noun decomposition for fine-grained action labeling.",
  "version": "2.0",
  "objects": [
    {
      "name": "End Effector",
      "shape": "POLYGON",
      "description": "The robot's end effector (gripper/hand) performing manipulation. Track across frames.",
      "attributes": [
        {
          "type": "radio",
          "name": "effector_side",
          "required": true,
          "options": ["left", "right", "both"]
        },
        {
          "type": "radio",
          "name": "effector_state",
          "required": true,
          "options": ["open", "closing", "grasping", "holding", "releasing"]
        },
        {
          "type": "radio",
          "name": "grasp_type",
          "required": false,
          "options": ["power_grasp", "pinch_grasp", "hook_grasp", "precision_grasp", "palmar_grasp", "none"]
        },
        {
          "type": "radio",
          "name": "contact_type",
          "required": false,
          "options": ["single_hand", "bimanual", "bracing", "whole_body", "no_contact"]
        }
      ]
    },
    {
      "name": "Manipulated Object",
      "shape": "POLYGON",
      "description": "Object the robot is currently interacting with or about to interact with.",
      "attributes": [
        {
          "type": "radio",
          "name": "object_category",
          "required": true,
          "options": [
            "cup_mug",
            "bottle",
            "plate_bowl",
            "food_item",
            "utensil",
            "container_box",
            "bag",
            "cloth_towel",
            "tool",
            "remote_device",
            "book_paper",
            "door_handle",
            "drawer_handle",
            "knob_switch",
            "key",
            "phone",
            "other"
          ]
        },
        {
          "type": "checklist",
          "name": "object_property",
          "required": false,
          "options": [
            "rigid",
            "deformable",
            "transparent",
            "fragile",
            "heavy",
            "small",
            "articulated"
          ]
        },
        {
          "type": "radio",
          "name": "manipulation_verb",
          "required": true,
          "options": [
            "reach",
            "grasp",
            "lift",
            "carry",
            "place",
            "release",
            "push",
            "pull",
            "open",
            "close",
            "rotate",
            "insert",
            "slide",
            "press",
            "hold",
            "pour",
            "wipe",
            "tear",
            "fold",
            "stack",
            "none"
          ]
        }
      ]
    },
    {
      "name": "Target Surface",
      "shape": "POLYGON",
      "description": "Where the object is being placed on or retrieved from.",
      "attributes": [
        {
          "type": "radio",
          "name": "surface_type",
          "required": true,
          "options": [
            "table",
            "countertop",
            "shelf",
            "floor",
            "drawer",
            "cabinet",
            "sink",
            "appliance_surface",
            "bed",
            "chair_sofa",
            "hook_rack",
            "bin_trash",
            "other"
          ]
        },
        {
          "type": "radio",
          "name": "surface_height",
          "required": false,
          "options": ["ground_level", "low", "waist_height", "chest_height", "overhead"]
        }
      ]
    },
    {
      "name": "Obstacle",
      "shape": "POLYGON",
      "description": "Objects or elements that affect robot navigation or safe manipulation.",
      "attributes": [
        {
          "type": "radio",
          "name": "obstacle_type",
          "required": true,
          "options": ["person", "pet", "furniture", "wall_fixture", "cord_cable", "clutter", "fragile_item", "other"]
        },
        {
          "type": "radio",
          "name": "proximity",
          "required": false,
          "options": ["in_path", "adjacent", "distant"]
        }
      ]
    }
  ],
  "frame_classifications": [
    {
      "name": "Manipulation Phase",
      "description": "High-level manipulation phase the robot is currently in. One label per frame.",
      "type": "radio",
      "required": true,
      "options": [
        "idle",
        "approaching_object",
        "pre_grasp_positioning",
        "grasping",
        "transporting",
        "placing",
        "post_place_retract",
        "tool_use",
        "bimanual_coordination",
        "recovery_adjustment"
      ]
    },
    {
      "name": "Scene Context",
      "description": "Physical room or area context for the current frame.",
      "type": "radio",
      "required": true,
      "options": [
        "kitchen",
        "living_room",
        "bedroom",
        "bathroom",
        "hallway",
        "office_workspace",
        "garage_utility",
        "dining_area",
        "entryway",
        "other"
      ]
    },
    {
      "name": "Video Quality",
      "description": "Quality flags for curation and filtering.",
      "type": "checklist",
      "required": false,
      "options": [
        "camera_shake",
        "motion_blur",
        "occlusion_heavy",
        "low_light",
        "overexposed",
        "depth_artifact",
        "clean"
      ]
    },
    {
      "name": "Task Outcome",
      "description": "Task completion status (annotate on final frames of task sequence).",
      "type": "radio",
      "required": false,
      "options": [
        "success",
        "partial_success",
        "failed_dropped",
        "failed_unreachable",
        "in_progress"
      ]
    },
    {
      "name": "Motion Mode",
      "description": "Whether the robot base is moving during manipulation. Critical for mobile manipulators.",
      "type": "radio",
      "required": false,
      "options": [
        "stationary_manipulating",
        "walking_carrying",
        "walking_empty",
        "turning",
        "transitioning"
      ]
    }
  ]
}
