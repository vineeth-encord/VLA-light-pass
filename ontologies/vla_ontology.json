{
  "title": "VLA Egocentric — Dasher Delivery",
  "description": "Vision-Language-Action ontology for egocentric video annotation. Designed for training VLA models on last-mile delivery tasks. Compatible with OpenVLA, RT-2, Octo, and Gato-style action specifications.",
  "version": "1.0",
  "objects": [
    {
      "name": "Active Hand",
      "shape": "POLYGON",
      "description": "The dominant/active hand performing an action. Track across frames.",
      "attributes": [
        {
          "type": "radio",
          "name": "hand_side",
          "required": true,
          "options": ["left", "right", "both"]
        },
        {
          "type": "radio",
          "name": "hand_state",
          "required": true,
          "options": ["empty", "holding_rigid", "holding_flexible", "in_contact", "reaching"]
        },
        {
          "type": "radio",
          "name": "grasp_type",
          "required": false,
          "options": ["power_grasp", "pinch_grasp", "hook_grasp", "none"]
        }
      ]
    },
    {
      "name": "Manipulated Object",
      "shape": "BOUNDING_BOX",
      "description": "Object the agent is currently interacting with or about to interact with.",
      "attributes": [
        {
          "type": "radio",
          "name": "object_category",
          "required": true,
          "options": [
            "package_bag",
            "package_box",
            "package_envelope",
            "food_container",
            "food_bag",
            "beverage",
            "door_handle",
            "doorbell",
            "keypad",
            "mailbox",
            "phone_device",
            "other"
          ]
        },
        {
          "type": "checklist",
          "name": "affordances",
          "required": false,
          "options": [
            "graspable",
            "pushable",
            "openable",
            "pressable",
            "liftable",
            "fragile",
            "heavy"
          ]
        },
        {
          "type": "radio",
          "name": "interaction_phase",
          "required": true,
          "options": ["approaching", "grasping", "carrying", "placing", "releasing", "none"]
        }
      ]
    },
    {
      "name": "Target Location",
      "shape": "BOUNDING_BOX",
      "description": "Where the object is being delivered to or retrieved from.",
      "attributes": [
        {
          "type": "radio",
          "name": "location_type",
          "required": true,
          "options": [
            "front_door",
            "doorstep",
            "mailbox",
            "lobby_desk",
            "locker",
            "hand_to_person",
            "doorman",
            "other"
          ]
        },
        {
          "type": "radio",
          "name": "accessibility",
          "required": false,
          "options": ["direct_access", "requires_keypad", "requires_doorbell", "requires_buzzer", "gated"]
        }
      ]
    },
    {
      "name": "Person / Recipient",
      "shape": "BOUNDING_BOX",
      "description": "Any person visible in the scene, especially the recipient of delivery.",
      "attributes": [
        {
          "type": "radio",
          "name": "person_role",
          "required": true,
          "options": ["recipient", "bystander", "doorman", "unknown"]
        },
        {
          "type": "radio",
          "name": "attention_state",
          "required": false,
          "options": ["looking_at_agent", "aware_of_agent", "unaware", "approaching"]
        }
      ]
    },
    {
      "name": "Obstacle / Hazard",
      "shape": "BOUNDING_BOX",
      "description": "Objects or elements that affect navigation or safe delivery.",
      "attributes": [
        {
          "type": "radio",
          "name": "hazard_type",
          "required": true,
          "options": ["vehicle", "cyclist", "pedestrian", "step_curb", "wet_surface", "narrow_passage", "dog_animal", "other"]
        },
        {
          "type": "radio",
          "name": "severity",
          "required": false,
          "options": ["minor", "moderate", "blocking"]
        }
      ]
    }
  ],
  "frame_classifications": [
    {
      "name": "Action Phase",
      "description": "High-level action the agent is currently performing. One label per frame.",
      "type": "radio",
      "required": true,
      "options": [
        "navigating_to_location",
        "approaching_entrance",
        "interacting_with_access_control",
        "carrying_item",
        "placing_item",
        "handing_item_to_person",
        "scanning_confirming",
        "returning_to_vehicle",
        "waiting",
        "other"
      ]
    },
    {
      "name": "Scene Environment",
      "description": "Physical environment context for the current frame.",
      "type": "radio",
      "required": true,
      "options": [
        "outdoor_street",
        "outdoor_parking",
        "outdoor_path",
        "building_lobby",
        "building_hallway",
        "building_elevator",
        "apartment_corridor",
        "residential_front",
        "commercial_entrance",
        "other"
      ]
    },
    {
      "name": "Video Quality",
      "description": "Quality flags for curation and filtering.",
      "type": "checklist",
      "required": false,
      "options": [
        "camera_shake",
        "motion_blur",
        "occlusion_heavy",
        "low_light",
        "overexposed",
        "partial_frame",
        "clean"
      ]
    },
    {
      "name": "Task Completion",
      "description": "Final delivery outcome (annotate on last frame of clip).",
      "type": "radio",
      "required": false,
      "options": [
        "successful_delivery",
        "left_at_door",
        "handed_to_person",
        "failed_no_access",
        "failed_no_recipient",
        "returned_to_vehicle"
      ]
    }
  ]
}
